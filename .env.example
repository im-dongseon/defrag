# defrag Configuration Example
# Copy this file to .env and update the variables with your own settings.

# The absolute path to your Obsidian vault directory.
# Example (macOS): VAULT_DIR="/Users/yourname/Documents/defrag"
# Example (Linux): VAULT_DIR="/home/yourname/defrag"
# Example (Windows): VAULT_DIR="C:/Users/yourname/Documents/defrag"
VAULT_DIR="/path/to/your/defrag-vault"
